# Copy to .env (git-ignored) and fill in. Only OPENAI_API_KEY is required.
# The scheduler talks to the Bots over Bluetooth directly — no SwitchBot cloud token needed.
OPENAI_API_KEY=sk-...
# Optional overrides:
# SWITCHBOT_DEVICES=devices.yaml
# PORT=8000

# --- Home Family Agent (Telegram) ---
TELEGRAM_BOT_TOKEN=123456:your-botfather-token
# Space/comma-separated Telegram chat IDs allowed to command the bot (your family group).
# Leave EMPTY to run in discovery mode: the bot replies with each chat's ID so you can fill this in.
ALLOWED_CHAT_IDS=
# Optional overrides:
HOME_AGENT_MODEL=gpt-4o
HOME_AGENT_DB=home_agent.db

# --- Roborock Q Revo (vacuum) ---
# Roborock account email; unset -> vacuum tools don't load (bot still runs).
ROBOROCK_USERNAME=you@example.com
# Auth is EITHER a saved token file (preferred; required for Google/email-code accounts that have no
# password) OR a password. The token file is created once via scripts/roborock_login.py and is
# git-ignored. Password login only works for accounts that actually have a Roborock password.
# ROBOROCK_USERDATA=roborock_userdata.json
# ROBOROCK_PASSWORD=your-roborock-password
# Optional: path to the room registry (segment-id <-> Hebrew room names).
# ROBOROCK_ROOMS=roborock_rooms.yaml

# --- finance (Discount bank, read-only) ---
# All three required to enable finance tools; partial config disables them.
DISCOUNT_ID=your-id
DISCOUNT_PASSWORD=your-password
DISCOUNT_NUM=your-user-code
# FINANCE_NODE_BIN=node
# FINANCE_COLLECTOR_SCRIPT=collector/scrape_discount.js
# Optional: point the collector's headless browser at a specific Chrome instead of Puppeteer's
# bundled Chromium. Needed on macOS if the bundled Chrome-for-Testing fails to install; the Linux
# box normally uses the bundled one and can leave this unset.
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
